# ── Database (Neon - free at neon.tech) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
UPLOAD_DIR=uploads

# ── Cloudinary (free at cloudinary.com — 25 GB) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay (razorpay.com) ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here

# ── Email / SMTP (Gmail App Password) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_EMAIL=Harsha Art Gallery <your@gmail.com>

# ── WhatsApp Business (Meta Cloud API) ───────────────────────────────────────
WHATSAPP_NUMBER=919876543210
WHATSAPP_API_TOKEN=your_meta_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=harsha_gallery_verify_2025

# ── Replicate AI (replicate.com) ──────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_your_token_here

# ── Instagram (Meta Graph API) ────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_BUSINESS_ID=your_ig_business_id

# ── Public URLs (set after deploying to Render + Vercel) ─────────────────────
PUBLIC_BASE_URL=https://harsha-gallery-api.onrender.com
PUBLIC_FRONTEND_URL=https://harsha-gallery.vercel.app
